\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Logo\\Logo.js",["109","110"],"import react from 'react';\r\nimport classes from './Logo.module.css';\r\nimport main_logo from '../../assets/images/ohana_trans.png';\r\nimport Auxi from '../../hoc/Auxiliary';\r\n\r\nconst logo = () => {\r\n    return (\r\n        <div>\r\n            <img src={main_logo} alt=\"Ohana project main logo\" className={classes.LogoImg} />\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default logo;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Header\\HeaderItens\\HeaderItens.js",["111","112"],"import React, { useEffect, useState } from 'react';\r\nimport classes from './HeaderItens.module.css';\r\n\r\nconst HeaderItens = (props) => {\r\n\r\n\r\n    return (\r\n        <div className={classes.MenuContainer}>\r\n\r\n            <div id=\"left-itens-div\">\r\n                <a href=\"/\"\r\n                    className={classes.MenuItem}>\r\n                    Plataforma\r\n                </a>\r\n            </div>\r\n\r\n            <div id=\"right-itens-div\">\r\n                <a href=\"/\"\r\n                    className={[classes.MenuItem, classes.active].join(\" \")}>\r\n                    Notícias\r\n                </a>\r\n                <a href=\"/\"\r\n                    className={classes.MenuItem}>\r\n                    Vídeos\r\n                </a>\r\n                <a href=\"/\"\r\n                    className={classes.MenuItem}>\r\n                    Análises\r\n                </a>\r\n                <a href=\"/\"\r\n                    className={classes.MenuItem}>\r\n                    Artigos\r\n                </a>\r\n            </div>\r\n\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default HeaderItens;",["113","114"],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Header\\HeaderIcons\\HeaderIcons.js",["115"],"import react from 'react';\r\nimport classes from './HeaderIcons.module.css';\r\nimport twitch from '../../../assets/images/twitch.png';\r\nimport facebook from '../../../assets/images/facebook.png';\r\nimport instagram from '../../../assets/images/instagram.png';\r\nimport youtube from '../../../assets/images/youtube.png';\r\n\r\n\r\nconst headerIcons = (props) => {\r\n\r\n    const figures = [{ id: \"twitch-icon\", icon: twitch, alt: \"twitch icon\" },\r\n    { id: \"facebook-icon\", icon: facebook, alt: \"facebook icon\" },\r\n    { id: \"youtube-icon\", icon: youtube, alt: \"youtube icon\" },\r\n    { id: \"instagram-icon\", icon: instagram, alt: \"instagram icon\" }];\r\n\r\n    const itens = figures.map(el =>\r\n        <div className={classes.iconsContainer} key={el.id}>\r\n            <img src={el.icon} alt={el.alt} className={classes.mediaIcons} />\r\n            <div className={classes.hoverEffect}></div>\r\n        </div>)\r\n\r\n    return (\r\n        <div>\r\n            {itens}\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default headerIcons;",["116","117"],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\index.js",[],["118","119"],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Featured\\FeaturedMenu\\Featured.js",["120","121","122"],"import React, { useRef, useEffect, useState, Component } from 'react';\r\nimport classes from './Featured.module.css';\r\nimport FeaturedItem from '../FeaturedItens/FeaturedItens';\r\nimport { getRandomGame } from '../../../development';\r\n\r\nclass Featured extends Component {\r\n\r\n    state = {\r\n        isSticky: false,\r\n        isOver: false,\r\n        lastWindowYOffset: 0,\r\n        lastScrollYOffset: 0,\r\n        isTicking: 0,\r\n        scrolldelay: 1,\r\n        transform: 0\r\n    }\r\n\r\n    scrollBar = React.createRef();\r\n    scroll = React.createRef();\r\n    featured = React.createRef();\r\n\r\n    // componentDidMount () {\r\n    //     window.addEventListener('scroll', this.handleScroll);\r\n    // }\r\n\r\n    // componentWillUnmount() {\r\n    //     window.removeEventListener('scroll', this.handleScroll);\r\n    // }\r\n\r\n    // handleScroll = (event) =>{\r\n    //     let scrollTop = event.srcElement.body.scrollTop,\r\n    //         itemTranslate = Math.min(0, scrollTop/3 - 60);\r\n\r\n    //     this.setState({transform: itemTranslate});\r\n    // }\r\n\r\n    componentDidMount() {\r\n        window.addEventListener('scroll', () => this.scrollHandler())\r\n    }\r\n\r\n    shouldComponentUpdate(nextProps, nextState) {\r\n        return false\r\n    }\r\n\r\n    scrollHandler = () => {\r\n\r\n        if (window.pageYOffset >= document.getElementById('banner-content').clientHeight) {\r\n            this.setState({ isSticky: true })\r\n        } else if (window.pageYOffset <= document.getElementById('banner-content').clientHeight) {\r\n            this.setState({ isSticky: false })\r\n        }\r\n\r\n\r\n        // let yOffset = this.state.lastScrollYOffset + (window.scrollY / Math.abs(window.scrollY)) * this.state.scrolldelay;\r\n        // console.log(yOffset)\r\n        // if (this.state.isOver) {\r\n\r\n        //     window.scrollTo(0, this.state.lastWindowYOffset)\r\n\r\n        //     const maxScrollHeight = this.scrollBar.current.clientHeight - this.scroll.current.clientHeight;\r\n\r\n        //     if (!this.state.isTicking) {\r\n        //         window.requestAnimationFrame(() => {\r\n\r\n        //             if (yOffset < maxScrollHeight) {\r\n        //                 this.scroll.current.style.top = `${yOffset}px`;\r\n        //             } else if (yOffset < 0) {\r\n        //                 this.scroll.current.style.top = `0px`;\r\n        //             } else {\r\n        //                 this.scroll.current.style.top = `${maxScrollHeight}px`;\r\n        //                 yOffset = maxScrollHeight;\r\n        //             }\r\n        //             this.setState({ isTicking: false, lastScrollYOffset: yOffset })\r\n\r\n        //         });\r\n\r\n        //         this.setState({ isTicking: true })\r\n        //     }\r\n\r\n\r\n\r\n        // } else {\r\n\r\n        //     this.state.lastWindowYOffset = window.scrollY;\r\n        // }\r\n\r\n\r\n    }\r\n\r\n\r\n\r\n    render() {\r\n\r\n        // const mouseEvent = (flag) => {\r\n        //     if (!flag) {\r\n        //         this.setState({ lastWindowYOffset: window.scrollY });\r\n        //         // window.scrollTo(0, window.scrollY)\r\n        //     } else {\r\n\r\n        //         // window.scrollTo(0, this.state.lastWindowYOffset)\r\n        //     }\r\n        //     this.setState({ isOver: flag })\r\n        // }\r\n\r\n        return (\r\n            <section className={[classes.FeaturedMain, this.state.isSticky ? classes.sticky : null].join(\" \")}\r\n                ref={this.featured}>\r\n\r\n                <div className={[classes.grid, classes.ItensContainer].join(\" \")}>\r\n\r\n                    <FeaturedItem gridPosition={classes.firstItem} bigItem showExpanded item={getRandomGame()}>Item1</FeaturedItem>\r\n                    <FeaturedItem gridPosition={classes.secondItem} item={getRandomGame()}>Item2</FeaturedItem>\r\n                    <FeaturedItem gridPosition={classes.thirdItem} item={getRandomGame()}>Item3</FeaturedItem>\r\n                    <FeaturedItem gridPosition={classes.fourthItem} item={getRandomGame()}>Item4</FeaturedItem>\r\n                    <FeaturedItem gridPosition={classes.fifthItem} item={getRandomGame()}>Item5</FeaturedItem>\r\n                    <FeaturedItem gridPosition={classes.sixthItem} item={getRandomGame()}>Item6</FeaturedItem>\r\n\r\n                    <div className={classes.scroll} ref={this.scrollBar}>\r\n                        <div className={classes.scrollBar} ref={this.scroll} >\r\n\r\n                        </div>\r\n                    </div>\r\n\r\n                </div>\r\n\r\n            </section>\r\n        )\r\n    }\r\n\r\n\r\n\r\n}\r\n\r\nexport default Featured;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Footer\\FooterItem\\FooterItem.js",["123"],"import React from 'react';\r\nimport classes from './FooterItem.module.css';\r\n\r\nconst footItem = (props) => {\r\n    return (\r\n        <div >\r\n            <div className={classes.FootItem}>\r\n\r\n                <img src={props.img} className={classes.icon} />\r\n\r\n                {props.children}\r\n            </div>\r\n        </div>\r\n    )\r\n};\r\n\r\nexport default footItem;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Footer\\Footer.js",["124"],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\hoc\\Auxiliary.js",[],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Footer\\FooterIcon\\FooterIcon.js",["125","126"],"import React from 'react';\r\nimport classes from './FooterIcon.module.css';\r\n\r\nconst footerIcon = (props) => {\r\n    return (\r\n        <div className={classes.container}>\r\n            <a href={props.linkRef} target=\"_blank\">\r\n                <div className={classes.imgContainer}>\r\n                    <img src={props.img} className={classes.icon} />\r\n                    <div className={classes.iconOverlay} />\r\n                </div>\r\n            </a>\r\n        </div>\r\n    )\r\n};\r\n\r\nexport default footerIcon;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Featured\\FeaturedItens\\FeaturedItens.js",["127","128","129","130","131","132","133","134","135","136"],"import React, { useRef, useState } from 'react';\r\nimport classes from './FeaturedItens.module.css';\r\nimport test from '../../../assets/images/game.jpg';\r\nimport ExpandedItem from './ExpandedFeaturedItem/ExpandedFeaturedItem';\r\nimport Aux from '../../../hoc/Auxiliary';\r\n\r\nconst FeaturedItens = (props) => {\r\n    // className={props.bigItem? classes.BigItem : classes.SmallItem}\r\n\r\n    const item = useRef();\r\n    const [timeOver, setTimeOver] = useState(0);\r\n    const [initialTime, setInitialTime] = useState(0);\r\n    const [show, setShow] = useState(false);\r\n    let teste = false;\r\n\r\n    const trimText = (str, bigText) => {\r\n        if (bigText) {\r\n            return str.slice(0, 83) + \"...\";\r\n        } else {\r\n            return str.slice(0, 70) + \"...\";\r\n        }\r\n    }\r\n\r\n    const testStr = \"Aqui vai o texto informativo sobre a noticia em destaque, meu querido! \" +\r\n        \"Esse é um teste também para o comprimeto do texto. É bem importante que o texto seja reduzido\" +\r\n        \"de forma correta por aqui.\"\r\n\r\n    return (\r\n        <Aux>\r\n            <ExpandedItem show={show}>Aqui vai um teste</ExpandedItem>\r\n            <div className={[props.bigItem ? classes.BigItem : classes.SmallItem, props.gridPosition].join(\" \")}>\r\n                <div className={props.bigItem ? classes.gridBigItem : classes.gridSmallItem}>\r\n                    <div className={classes.frontCover}>\r\n\r\n                    </div>\r\n\r\n                    <img src={props.item.img} alt=\"image\" className={props.bigItem ? classes.imageBigItem : classes.imageSmallItem} />\r\n                    <p>{trimText(props.item.text, props.bigItem)}</p>\r\n                </div>\r\n            </div>\r\n        </Aux>\r\n\r\n    )\r\n}\r\n\r\nexport default FeaturedItens;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\Featured\\FeaturedItens\\ExpandedFeaturedItem\\ExpandedFeaturedItem.js",["137"],"import React from 'react';\r\nimport classes from './ExpandedFeaturedItem.module.css';\r\nimport Aux from '../../../../hoc/Auxiliary';\r\n\r\nconst ExpandedFeaturedItem = (props) => {\r\n\r\n    return (\r\n        <div className={props.show ? null : classes.Hidden}>\r\n            <div className={classes.ItemModal}>\r\n                {props.children}\r\n            </div>\r\n            <div className={classes.Backdrop}>\r\n\r\n            </div>\r\n        </div>\r\n\r\n    )\r\n}\r\n\r\nexport default ExpandedFeaturedItem;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\MainContent\\MainContent.js",[],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\MainContent\\FeaturedContent\\FeaturedContent.js",["138","139","140"],"import React, { useState } from 'react';\r\nimport classes from './FeaturedContent.module.css';\r\nimport Item from './FeaturedContentItem/FeaturedContentItem';\r\nimport { getRandomGame } from '../../../development';\r\n\r\nconst NewsContent = (props) => {\r\n\r\n    const [filterFlags, setfilterFlags] = useState([true, false, false])\r\n\r\n    const setFlagValue = (index) => {\r\n        const newArray = [false, false, false];\r\n        newArray[index] = true;\r\n        setfilterFlags(newArray);\r\n    }\r\n\r\n    return (\r\n        <div className={classes.MainContent}>\r\n            <div className={classes.TimeFilter}>\r\n                <a className={filterFlags[0] ? classes.timeTextActive : classes.timeText}\r\n                    onClick={() => setFlagValue(0)}>\r\n                    HOJE\r\n                        </a>\r\n                <a className={filterFlags[1] ? classes.timeTextActive : classes.timeText}\r\n                    onClick={() => setFlagValue(1)}>\r\n                    ESTA SEMANA\r\n                    </a>\r\n                <a className={filterFlags[2] ? classes.timeTextActive : classes.timeText}\r\n                    onClick={() => setFlagValue(2)}>\r\n                    ESTE MÊS\r\n                    </a>\r\n            </div>\r\n            <p className={classes.HeaderText}>Em destaque</p>\r\n            <hr className={classes.HorizontalDivider} />\r\n\r\n            <div className={classes.ContentListContainer}>\r\n                <Item item={getRandomGame()}/>\r\n                <Item item={getRandomGame()}/>\r\n                <Item item={getRandomGame()}/>\r\n                <Item item={getRandomGame()}/>\r\n                <Item item={getRandomGame()}/>\r\n                <Item item={getRandomGame()}/>\r\n            </div>\r\n\r\n\r\n        </div >\r\n    )\r\n}\r\n\r\nexport default NewsContent;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\MainContent\\FeaturedContent\\FeaturedContentItem\\FeaturedContentItem.js",["141","142","143","144","145"],"import React, { useRef, useState } from 'react';\r\nimport classes from './FeaturedContentItem.module.css';\r\nimport test from '../../../../assets/images/game.jpg';\r\nimport Aux from '../../../../hoc/Auxiliary';\r\n\r\nconst FeaturedContentItem = (props) => {\r\n\r\n    const trimText = (str, bigText) => {\r\n        if (bigText) {\r\n            return str.slice(0, 83) + \"...\";\r\n        } else {\r\n            return str.slice(0, 70) + \"...\";\r\n        }\r\n    }\r\n\r\n\r\n    const testStr = \"Aqui vai o texto informativo sobre a noticia em destaque, meu querido! \" +\r\n        \"Esse é um teste também para o comprimeto do texto. É bem importante que o texto seja reduzido\" +\r\n        \"de forma correta por aqui.\"\r\n\r\n    return (\r\n        <Aux>\r\n            <div className={classes.Item}>\r\n                <img src={props.item.img} alt=\"image\" className={classes.imageItem} />\r\n                <p className={classes.Text}>{trimText(props.item.text, true)}</p>\r\n            </div>\r\n        </Aux>\r\n\r\n    )\r\n}\r\n\r\nexport default FeaturedContentItem;","C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\MainContent\\NewsContent\\NewsContent.js",[],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\MainContent\\NewsContent\\NewsContentItem\\NewsContentItem.js",["146","147","148","149","150","151","152","153","154","155","156"],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\MainContent\\SideContent\\HeaderFilter\\HeaderFilter.js",["157","158","159"],"import React, { useState } from 'react';\r\nimport classes from './HeaderFilter.module.css';\r\n\r\nconst HeaderFilter = (props) => {\r\n    const [filterFlags, setfilterFlags] = useState([true, false, false])\r\n\r\n    const setFlagValue = (index) => {\r\n        const newArray = [false, false, false];\r\n        newArray[index] = true;\r\n        setfilterFlags(newArray);\r\n    }\r\n    return (\r\n        <div>\r\n            <div className={classes.TimeFilter}>\r\n                <a className={filterFlags[0] ? classes.timeTextActive : classes.timeText}\r\n                    onClick={() => setFlagValue(0)}>\r\n                    Análises\r\n                        </a>\r\n                <p>/</p>\r\n                <a className={filterFlags[1] ? classes.timeTextActive : classes.timeText}\r\n                    onClick={() => setFlagValue(1)}>\r\n                    Lançamentos\r\n                    </a>\r\n                <p>/</p>\r\n                <a className={filterFlags[2] ? classes.timeTextActive : classes.timeText}\r\n                    onClick={() => setFlagValue(2)}>\r\n                    Vídeos\r\n                    </a>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default HeaderFilter;",["160","161"],"C:\\Users\\chris\\OneDrive\\Documentos\\react_course\\projeto-ohana\\ohana-project\\src\\components\\MainContent\\SideContent\\SideContent.js",["162","163"],"import React, { useState, useEffect } from 'react';\r\nimport classes from './SideContent.module.css';\r\nimport HeaderFilter from './HeaderFilter/Heade